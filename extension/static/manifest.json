{
  "manifest_version": 3,
  "name": "Apartment Messenger - ImmoScout24 Edition",
  "version": "1.11.1",
  "description": "Automatically contacts landlords on ImmoScout24 when new listings appear",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "notifications",
    "downloads",
    "sidePanel"
  ],
  "host_permissions": [
    "https://www.immobilienscout24.de/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.immobilienscout24.de/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

{
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "setup": "npm install && npm run setup -w @repo/documents",
    "dev": "concurrently \"npm run dev -w apps/server\" \"npm run dev -w apps/extension\"",
    "build": "npm run build -w apps/extension",
    "test": "npm run test -w packages/shared-prompts",
    "typecheck": "npm run check -w apps/extension && npm run typecheck -w apps/server",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "concurrently": "^9.0.0"
  }
}
